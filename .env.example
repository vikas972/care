# App
APP_BASE_URL=http://localhost:8000
# Browser / Swagger CORS (comma-separated). Include http://localhost:5173 when using the demo UI.
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://localhost:5173,http://127.0.0.1:5173
# After Google OAuth, redirect browser to demo UI with token (leave empty to return JSON only).
FRONTEND_OAUTH_REDIRECT_URL=http://localhost:5173/oauth/callback
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# Fernet key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Database
DATABASE_URL=postgresql+psycopg2://smartcall:smartcall@postgres:5432/smartcall

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Google OAuth (Calendar readonly)
# Local: use http://localhost:8000/... NOT https:// — Docker uvicorn has no certificate.
# https://localhost → ERR_SSL_PROTOCOL_ERROR and "Invalid HTTP request" in API logs.
#
# REQUIRED for calendar sync: In Google Cloud Console → APIs & Services → Library,
# enable "Google Calendar API" for this project. Without it, sync returns 403.
# If you signed in before adding Calendar scope: revoke the app at
# https://myaccount.google.com/permissions and sign in again.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# Exotel (Mumbai: api.in.exotel.com, Singapore: api.exotel.com)
EXOTEL_API_KEY=
EXOTEL_API_TOKEN=
EXOTEL_ACCOUNT_SID=
EXOTEL_SUBDOMAIN=api.in.exotel.com
EXOTEL_CALLER_ID=
# ExoML flow URL from Exotel dashboard (customer connects here after pickup)
EXOTEL_FLOW_URL=http://my.exotel.in/exoml/start/YOUR_APP_ID
EXOTEL_WEBHOOK_SECRET=change-me
# Set true to skip real HTTP calls to Exotel (dev)
EXOTEL_DRY_RUN=false

# Twilio (optional alternative to Exotel; users pick provider in dashboard)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Your Twilio number, E.164 e.g. +17406597732
TWILIO_FROM_NUMBER=
TWILIO_DRY_RUN=false
# HTTPS origin Twilio uses for TwiML + webhooks (no path, no trailing slash). Required if APP_BASE_URL is localhost.
# Copy from ngrok "Forwarding" or http://127.0.0.1:4040 — ngrok must tunnel the same port the API listens on.
TWILIO_WEBHOOK_PUBLIC_URL=
# Set false only for local debugging without valid signatures (not for production).
TWILIO_VALIDATE_WEBHOOK_SIGNATURES=true

# LiveKit (for Voice Agent UI tokens)
LIVEKIT_URL=wss://livekit.genaiforge.in
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Firebase (Phone OTP login)
FIREBASE_SERVICE_ACCOUNT_FILE=

# Reminders
CALENDAR_REMINDER_MINUTES_BEFORE=15
# Retry attempts after the initial call. 1 => at most 2 total calls.
CALL_RETRY_MAX=1
CALL_RETRY_DELAY_SECONDS=120
SWEEP_INTERVAL_SECONDS=30
