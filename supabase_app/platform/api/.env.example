# Run from platform/api: uvicorn voice_bff.main:app --reload --host 0.0.0.0 --port 8001
# Point the SPA (VITE_API_BASE_URL) at this origin. Never commit .env or service_role keys.

APP_BASE_URL=http://localhost:8001
CORS_ORIGINS=http://localhost:5174,http://127.0.0.1:5174,http://localhost:5173,http://127.0.0.1:5173

