FROM python:3.12-slim
WORKDIR /app

RUN touch /app/.env

COPY supabase/backend/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY supabase/backend/voice_bff ./voice_bff

ENV PYTHONPATH=/app
EXPOSE 8080

CMD ["uvicorn", "voice_bff.main:app", "--host", "0.0.0.0", "--port", "8080"]
